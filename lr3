<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Image Gallery</title>
    <style>
        /* === Базові налаштування === */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f7f9f4; /* Світлий фон сторінки */
            color: #333;
        }

        /* === Шапка сторінки === */
        header {
            background-color: #2b4d3b; /* Темно-зелений колір */
            color: white;
            text-align: center;
            padding: 30px 20px;
            margin-bottom: 20px;
        }

        header h1 {
            font-size: 3rem;
            font-family: serif;
            letter-spacing: 1px;
        }

        /* === Основний контент === */
        main {
            max-width: 900px;
            margin: 0 auto;
            padding: 20px;
            text-align: center;
        }

        .category-title {
            font-size: 2rem;
            margin-bottom: 20px;
            font-weight: bold;
            color: #222;
        }

        /* === Сітка галереї (CSS Grid) === */
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr); /* 3 рівні колонки */
            gap: 20px;
            margin-bottom: 40px;
        }

        /* Налаштування ширини для конкретних зображень згідно з макетом */
        .item-1, .item-2, .item-3 { grid-column: span 1; }
        .item-4 { grid-column: span 1; }
        .item-5 { grid-column: span 2; } /* Широке зображення водоспаду */
        .item-6 { grid-column: span 2; } /* Широке зображення дерева */
        .item-7 { grid-column: span 1; }

        /* === Стилізація карток (фігур) === */
        figure {
            background-color: transparent;
            border-radius: 8px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        /* Контейнер для зображення (для ефекту масштабування) */
        .img-container {
            overflow: hidden;
            border-radius: 8px;
            cursor: pointer;
            height: 200px; /* Фіксована висота для мініатюр */
        }

        figure img {
            width: 100%;
            height: 100%;
            object-fit: cover; /* Зображення заповнює блок без спотворень пропорцій */
            transition: transform 0.4s ease;
        }

        /* Ефект при наведенні */
        figure img:hover {
            transform: scale(1.1);
        }

        figcaption {
            margin-top: 10px;
            font-size: 1rem;
            color: #555;
        }

        /* === Кнопка === */
        .btn-kupita {
            background-color: #2b4d3b;
            color: white;
            border: none;
            padding: 12px 40px;
            font-size: 1.1rem;
            font-weight: bold;
            border-radius: 8px;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        .btn-kupita:hover {
            background-color: #1e382b;
        }

        /* === Модальне вікно === */
        .modal {
            display: none; /* Приховано за замовчуванням */
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.85); /* Напівпрозорий чорний фон */
            justify-content: center;
            align-items: center;
        }

        .modal-content {
            max-width: 90%;
            max-height: 90%;
            border-radius: 5px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.5);
            animation: zoomIn 0.3s ease;
        }

        @keyframes zoomIn {
            from {transform: scale(0.8); opacity: 0;}
            to {transform: scale(1); opacity: 1;}
        }

        .close {
            position: absolute;
            top: 20px;
            right: 35px;
            color: #fff;
            font-size: 40px;
            font-weight: bold;
            cursor: pointer;
            transition: color 0.3s;
        }

        .close:hover {
            color: #ccc;
        }

        /* === Адаптивність (для мобільних пристроїв) === */
        @media (max-width: 768px) {
            .gallery-grid {
                grid-template-columns: 1fr; /* 1 колонка на мобільних */
            }
            .item-1, .item-2, .item-3, .item-4, .item-5, .item-6, .item-7 {
                grid-column: span 1;
            }
        }
    </style>
</head>
<body>

    <header>
        <h1>Image Gallery</h1>
    </header>

    <main>
        <h2 class="category-title">Nature</h2>
        
        <section class="gallery-grid">
            <figure class="item-1">
                <div class="img-container">
                    <img src="https://picsum.photos/id/1015/600/400" alt="Mountain lake" class="gallery-img">
                </div>
                <figcaption>Nature</figcaption>
            </figure>
            <figure class="item-2">
                <div class="img-container">
                    <img src="https://picsum.photos/id/1016/600/400" alt="Mountain scenery" class="gallery-img">
                </div>
                <figcaption>Nature</figcaption>
            </figure>
            <figure class="item-3">
                <div class="img-container">
                    <img src="https://picsum.photos/id/1020/600/400" alt="Deer" class="gallery-img">
                </div>
                <figcaption>Nature</figcaption>
            </figure>

            <figure class="item-4">
                <div class="img-container">
                    <img src="https://picsum.photos/id/1018/600/400" alt="Forest" class="gallery-img">
                </div>
                <figcaption>Nature</figcaption>
            </figure>
            <figure class="item-5">
                <div class="img-container">
                    <img src="https://picsum.photos/id/1019/800/400" alt="Waterfall" class="gallery-img">
                </div>
                <figcaption>Nature</figcaption>
            </figure>

            <figure class="item-6">
                <div class="img-container">
                    <img src="https://picsum.photos/id/1021/800/400" alt="Tree in a field" class="gallery-img">
                </div>
                <figcaption>Nature</figcaption>
            </figure>
            <figure class="item-7">
                <div class="img-container">
                    <img src="https://picsum.photos/id/1022/600/400" alt="Flower field" class="gallery-img">
                </div>
                <figcaption>Nature</figcaption>
            </figure>
        </section>

        <button class="btn-kupita">Kupita</button>
    </main>

    <div id="imageModal" class="modal">
        <span class="close">&times;</span>
        <img class="modal-content" id="fullImage">
    </div>

    <script>
        // === Логіка модального вікна ===
        const modal = document.getElementById("imageModal");
        const fullImage = document.getElementById("fullImage");
        const images = document.querySelectorAll(".gallery-img");
        const closeBtn = document.querySelector(".close");

        // Відкриття модального вікна при кліку на мініатюру
        images.forEach(img => {
            img.addEventListener("click", function() {
                modal.style.display = "flex"; // Використовуємо flex для центрування
                fullImage.src = this.src; // Передаємо джерело клікнутого зображення
            });
        });

        // Закриття при кліку на хрестик
        closeBtn.addEventListener("click", function() {
            modal.style.display = "none";
        });

        // Закриття при кліку на темний фон поза зображенням
        window.addEventListener("click", function(event) {
            if (event.target === modal) {
                modal.style.display = "none";
            }
        });
    </script>
</body>
</html>
